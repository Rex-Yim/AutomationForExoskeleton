.DS_Store
**/.DS_Store

# Python
__pycache__/
**/__pycache__/
*.pyc

# Large / local-only assets under data/ (other paths under data/ are tracked)
data/USC-HAD/USC-HAD_raw/
data/USC-HAD/usc_had_dataset.mat
data/HuGaDB/hugadb_dataset.mat
data/HuGaDB/v1_cleanup_github/

# LSTM training checkpoints (many files, regenerable; final nets live in models/*.mat)
models/lstm_checkpoints/
models/lstm_multiclass_checkpoints/

# LaTeX build artifacts (sources under docs/latex/ are tracked)
docs/latex/*.pdf
docs/latex/*.aux
docs/latex/*.bbl
docs/latex/*.blg
docs/latex/*.out
docs/latex/*.toc
docs/latex/*.log
docs/latex/*.synctex.gz
