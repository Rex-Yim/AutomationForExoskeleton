data/public/HuGaDB/hugadb_dataset.mat

# LSTM trainNetwork checkpoints (large)
models/lstm_checkpoints/

data/public/.DS_Store

# Deliverable PDFs at docs/final_report.pdf and docs/poster.pdf (copied from docs/latex/)
docs/final/

# LaTeX build artifacts (report + poster sources in docs/latex/)
docs/latex/*.aux
docs/latex/*.bbl
docs/latex/*.blg
docs/latex/*.out
docs/latex/*.toc
docs/latex/*.log
docs/latex/*.synctex.gz
