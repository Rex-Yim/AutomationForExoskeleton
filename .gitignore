.DS_Store
**/.DS_Store

# Python
__pycache__/
**/__pycache__/
*.pyc

# Datasets and generated caches (populate locally or unzip release bundle under data/)
/data/

# Release bundle built locally — attach to GitHub Releases instead of committing
AutomationForExoskeleton_data.zip

# LSTM training checkpoints (many files, regenerable; final nets live in models/*.mat)
models/lstm_checkpoints/
models/lstm_multiclass_checkpoints/

# LaTeX build artifacts (sources under docs/latex/ are tracked)
docs/latex/*.pdf
docs/latex/*.aux
docs/latex/*.bbl
docs/latex/*.blg
docs/latex/*.out
docs/latex/*.toc
docs/latex/*.log
docs/latex/*.synctex.gz
