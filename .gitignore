# LSTM trainNetwork checkpoints (large)
models/lstm_checkpoints/

data/public/.DS_Store

# LaTeX build artifacts (docs/latex — keep sources + main.pdf only)
docs/latex/*.aux
docs/latex/*.bbl
docs/latex/*.blg
docs/latex/*.out
docs/latex/*.toc
docs/latex/*.log
docs/latex/*.synctex.gz
